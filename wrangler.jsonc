{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "game-hub",
  "main": "./worker/index.ts",
  "compatibility_date": "2026-04-24",
  "routes": [
    {
      "pattern": "gamehub.hunao.online",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "observability": {
    "enabled": true
  }
}
